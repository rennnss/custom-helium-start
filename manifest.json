{
    "manifest_version": 3,
    "name": "Helium New Tab",
    "description": "A minimalist, high-performance search dashboard with 3D dithered aesthetics — replaces your new tab page.",
    "version": "1.0.0",
    "icons": {
        "16": "assets/icons/icon16.png",
        "48": "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://*.google.com/*"
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "theme": {
        "colors": {
            "frame": [
                21,
                38,
                113
            ],
            "frame_inactive": [
                21,
                38,
                113
            ],
            "toolbar": [
                21,
                38,
                113
            ],
            "tab_text": [
                255,
                255,
                255
            ],
            "tab_background_text": [
                255,
                255,
                255
            ],
            "bookmark_text": [
                255,
                255,
                255
            ],
            "ntp_background": [
                21,
                38,
                113
            ],
            "ntp_text": [
                255,
                255,
                255
            ]
        }
    }
}